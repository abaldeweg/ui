{
  "name": "@baldeweg/ui",
  "version": "0.18.1",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build",
    "test": "vitest run --environment jsdom",
    "docu": "storybook build --disable-telemetry",
    "generate-docu": "docu"
  },
  "dependencies": {
    "vue": "3.5.29"
  },
  "devDependencies": {
    "@baldeweg/docu": "workspace:*",
    "@baldeweg/eslint-config": "0.17.0",
    "@rushstack/eslint-patch": "1.16.1",
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/addon-docs": "9.1.20",
    "@storybook/vue3-vite": "9.1.20",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.0.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-storybook": "9.1.20",
    "eslint-plugin-vue": "10.8.0",
    "jsdom": "28.1.0",
    "prettier": "3.8.1",
    "start-server-and-test": "2.1.5",
    "storybook": "9.1.20",
    "storybook-addon-tag-badges": "3.0.6",
    "vite": "7.3.1",
    "vite-plugin-webfont-dl": "3.12.0",
    "vitest": "4.0.18"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/ui.umd.js",
  "module": "./dist/ui.es.js",
  "exports": {
    ".": {
      "import": "./dist/ui.es.js",
      "require": "./dist/ui.umd.js"
    },
    "./styles": "./dist/ui.css"
  },
  "author": "André Baldeweg <a@baldeweg.org>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abaldeweg/ui.git"
  },
  "type": "module"
}
